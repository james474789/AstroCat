# ===========================================
# AstroCat Environment Configuration
# ===========================================
# Copy this file to .env and update values for your environment.
# Never commit your actual .env file to version control.

# -------------------------------------------
# Demo/Test Configuration
# -------------------------------------------
DEMO_URL=http://localhost:8090
DEMO_USER=admin@example.com
DEMO_PASSWORD=your_demo_password_here

# -------------------------------------------
# Database Configuration (PostgreSQL + PostGIS)
# -------------------------------------------
POSTGRES_USER=AstroCat
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=AstroCat
DATABASE_URL=postgresql+asyncpg://AstroCat:your_strong_password_here@db:5432/AstroCat

# -------------------------------------------
# Backup Configuration
# -------------------------------------------
# Schedule (cron format or @daily, @weekly, etc.)
BACKUP_SCHEDULE=@daily
BACKUP_RETENTION_DAYS=7

# -------------------------------------------
# CSRF Protection
# -------------------------------------------
CSRF_ENABLED=false
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_COOKIE_SECURE=true
CSRF_COOKIE_SAMESITE=lax
CSRF_COOKIE_MAX_AGE=172800

# -------------------------------------------
# Redis Configuration
# -------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -------------------------------------------
# Cookie Security (Authentication)
# -------------------------------------------
# Set to true for HTTPS/production (prevents MITM attacks)
COOKIE_SECURE=false
# Cookie expiration in seconds (default: 172800 = 2 days)
COOKIE_MAX_AGE=172800
# SameSite policy: lax, strict, or none
COOKIE_SAMESITE=lax


# -------------------------------------------
# Backend Configuration
# -------------------------------------------
# Generate a secure secret key with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY_AT_LEAST_32_CHARS
AUTH_REQUIRED=true
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

# -------------------------------------------
# Image Storage Paths
# -------------------------------------------
# Container mount points for image scanning
IMAGE_PATH_1=./data/images
# Comma-separated list of container paths to scan
IMAGE_PATHS=/data/images,/data/mount2,/data/mount3

# -------------------------------------------
# Network Share Configuration (NAS)
# -------------------------------------------
# NAS credentials for CIFS mount (used in docker-compose)
NAS_USERNAME=your_nas_username
NAS_PASSWORD=your_nas_password
# UNC path to network shares (use forward slashes)
NAS_ASTRO_FINALS_PATH=//your-nas/path/to/finals
NAS_ASTRO_SOURCE_PATH=//your-nas/path/to/source

# -------------------------------------------
# Thumbnail Configuration
# -------------------------------------------
THUMBNAIL_CACHE_PATH=/data/thumbnails
THUMBNAIL_MAX_SIZE=400

# -------------------------------------------
# Frontend Configuration
# -------------------------------------------
VITE_API_URL=http://localhost:8089/api
CORS_ORIGINS=http://localhost:8090,http://127.0.0.1:8090

# -------------------------------------------
# Astrometry.net Configuration (Remote)
# -------------------------------------------
# Get your API key from http://nova.astrometry.net/api_help
ASTROMETRY_API_KEY=your_astrometry_net_api_key_here

# -------------------------------------------
# Local Astrometry Configuration (e.g. Stellarsolver-API)
# -------------------------------------------
LOCAL_ASTROMETRY_URL=http://localhost:8000/api
LOCAL_ASTROMETRY_API_KEY=XXXXXXXX