# ===========================================
# AstroCat Environment Configuration
# ===========================================
# Copy this file to .env and update values

# -------------------------------------------
# Database Configuration (PostgreSQL + PostGIS)
# -------------------------------------------
POSTGRES_USER=REPLACE_WITH_DB_USER
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
POSTGRES_DB=AstroCat
DATABASE_URL=postgresql+asyncpg://REPLACE_WITH_DB_USER:REPLACE_WITH_STRONG_DB_PASSWORD@db:5432/AstroCat

# -------------------------------------------
# Backup Configuration
# -------------------------------------------
BACKUP_SCHEDULE=@daily
BACKUP_RETENTION_DAYS=7

# -------------------------------------------
# Redis Configuration
# -------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -------------------------------------------
# Backend Configuration
# -------------------------------------------
# Generate a secure secret key with:
# python -c "import secrets; print(secrets.token_hex(32))"
# Or: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY_AT_LEAST_32_CHARS
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
PORT=8089

# -------------------------------------------
# Cookie Security (Authentication)
# -------------------------------------------
# Set to true for HTTPS/production (prevents MITM attacks)
COOKIE_SECURE=false
# Cookie expiration in seconds (default: 172800 = 2 days)
COOKIE_MAX_AGE=172800
# SameSite policy: lax, strict, or none
COOKIE_SAMESITE=lax

# -------------------------------------------
# Rate Limiting (DoS Protection)
# -------------------------------------------
# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true
# Login attempts (format: count/timeperiod)
RATE_LIMIT_LOGIN=5/15minutes
# Search queries
RATE_LIMIT_SEARCH=30/minute
# General API requests
RATE_LIMIT_GENERAL=100/minute

# -------------------------------------------
# CSRF Protection
# -------------------------------------------
CSRF_ENABLED=true
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_COOKIE_SECURE=false
CSRF_COOKIE_SAMESITE=lax
CSRF_COOKIE_MAX_AGE=172800

# -------------------------------------------
# Image Storage Paths (mount points)
# -------------------------------------------
# Comma-separated list of paths to scan for images
IMAGE_PATHS=/data/images

# -------------------------------------------
# Thumbnail Configuration
# -------------------------------------------
THUMBNAIL_CACHE_PATH=/data/thumbnails
THUMBNAIL_MAX_SIZE=400

# -------------------------------------------
# Frontend Configuration
# -------------------------------------------
VITE_API_URL=http://localhost:8089/api
FRONTEND_PORT=8090

# -------------------------------------------
# Astrometry.net Configuration
# -------------------------------------------
# Get your API key from http://nova.astrometry.net/api_help
ASTROMETRY_API_KEY=your_key_here

# Local Astrometry Configuration
# LOCAL_ASTROMETRY_URL=http://localhost:3000/api
# LOCAL_ASTROMETRY_API_KEY=XXXXXXXX
